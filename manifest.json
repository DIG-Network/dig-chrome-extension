{
  "manifest_version": 3,
  "name": "DIG Network Extension",
  "version": "1.28.4",
  "description": "The DIG Network on any browser: chia:// resolution (verified + decrypted), a Chia wallet, DIG Shields, node control, and the DIG dApp store \u2014 a clean 5-tab experience.",
  "host_permissions": [
    "http://localhost/*",
    "http://localhost:*/*",
    "http://127.0.0.1/*",
    "http://127.0.0.1:*/*",
    "http://dig.local/*",
    "https://dig.local/*",
    "http://*.dig.local/*",
    "https://*.dig.local/*",
    "https://rpc.dig.net/*",
    "https://*.dig.net/*",
    "https://coinset.org/*",
    "https://api.dexie.space/*",
    "https://api.bugreport.dig.net/*",
    "https://explore.dig.net/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://rpc.dig.net https://*.dig.net https://coinset.org https://api.dexie.space https://api.bugreport.dig.net wss://*.walletconnect.com wss://*.walletconnect.org https://*.walletconnect.com https://*.walletconnect.org; frame-src 'self' https:; font-src 'self'; img-src 'self' data: https://explore.dig.net"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "middleware.js",
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "src/favicon.png",
      "48": "src/favicon.png",
      "128": "src/favicon.png"
    }
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "src/favicon.png",
    "48": "src/favicon.png",
    "128": "src/favicon.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "page-script.js",
        "dig-provider.js",
        "logo.png",
        "dig-viewer.html",
        "agent-surface.json",
        "dig_client.js",
        "dig_client_bg.wasm",
        "vendor/walletconnect-sign-client.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "permissions": [
    "storage",
    "webNavigation",
    "tabs",
    "declarativeNetRequest",
    "scripting",
    "omnibox",
    "search",
    "notifications",
    "offscreen",
    "idle",
    "alarms"
  ],
  "omnibox": {
    "keyword": "dig"
  }
}
