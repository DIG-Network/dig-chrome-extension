{
  "manifest_version": 3,
  "name": "DIG Network Extension",
  "version": "1.0.0",
  "description": "Intercept and redirect dig:// protocol requests to localhost",
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://dig.local/*",
    "https://dig.local/*",
    "http://*.dig.local/*",
    "https://*.dig.local/*",
    "https://rpc.dig.net/*",
    "https://*.dig.net/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["middleware.js", "content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "src/favicon.png",
      "48": "src/favicon.png",
      "128": "src/favicon.png"
    }
  },
  "icons": {
    "16": "src/favicon.png",
    "48": "src/favicon.png",
    "128": "src/favicon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["page-script.js", "logo.png", "dig-viewer.html", "dig-viewer.js", "dig_client.js", "dig_client_bg.wasm"],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": [
    "storage",
    "webNavigation",
    "tabs",
    "declarativeNetRequest",
    "scripting",
    "omnibox",
    "search"
  ],
  "omnibox": {
    "keyword": "dig"
  }
}

